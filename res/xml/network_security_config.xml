<?xml version="1.0" encoding="utf-8"?>
<!--
    VULNERABILITY: Permissive network security config
    - Trusts user-installed CAs (enables Burp Suite interception without root)
    - Allows cleartext (HTTP) traffic to all domains
    - No cert pinning
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
